# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/preploom
MONGODB_URI_PROD=mongodb+srv://<username>:<password>@cluster.mongodb.net/preploom?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=PrepLoom <noreply@preploom.com>

# Cloudinary (File Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Frontend URL
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://preploom.com.ng

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Service (OpenAI or Custom)
OPENAI_API_KEY=sk-your-openai-api-key
AI_GRADING_ENDPOINT=https://api.openai.com/v1/chat/completions

# Admin Credentials (Initial Setup)
ADMIN_EMAIL=admin@preploom.com
ADMIN_PASSWORD=Admin@123456

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_AUDIO_SIZE=52428800
